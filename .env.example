# Trello MCP Server — пример переменных окружения.
# Скопируй в .env и заполни реальными значениями. Ключ и токен получают на
# https://trello.com/power-ups/admin (API key) и через /1/authorize (token).

# --- Обязательные ---
TRELLO_API_KEY=your-trello-api-key
TRELLO_TOKEN=your-trello-api-token
TRELLO_BOARD_ID=your-board-id

# --- Опциональные (значения по умолчанию) ---
TRELLO_API_BASE=https://api.trello.com/1
LOG_LEVEL=INFO
